# Nexora Crawl configuration
NEXORA_CRAWL_PORT=8080
NEXORA_CRAWL_API_KEY=change-me
NEXORA_CRAWL_TIMEOUT_MS=60000
NEXORA_CRAWL_ALLOWED_ORIGIN=*
NEXORA_CRAWL_OBSCURA_BIN=deps/obscura

# Native search engines (comma-separated): duckduckgo, brave, startpage
NEXORA_CRAWL_SEARCH_ENGINES=duckduckgo,brave,startpage
NEXORA_CRAWL_SEARCH_TIMEOUT_MS=30000
NEXORA_CRAWL_SEARCH_DEFAULT_LIMIT=10

# Optional proxy used for all outgoing requests (search + scrape)
# NEXORA_CRAWL_PROXY=
