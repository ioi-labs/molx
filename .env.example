# Molx configuration
PORT=8080
API_KEY=change-me
TIMEOUT_MS=60000
ALLOWED_ORIGIN=*
OBSCURA_BIN=deps/obscura

# Native search engines (comma-separated): duckduckgo, brave, startpage
SEARCH_ENGINES=duckduckgo,brave,startpage
SEARCH_TIMEOUT_MS=30000
SEARCH_DEFAULT_LIMIT=10

# Optional proxy used for all outgoing requests (search + scrape)
# PROXY=

# LLM provider for onlyCleanContent (OpenAI-compatible chat completions)
# LLM_BASE_URL=https://api.openai.com
# LLM_API_KEY=your-openai-key
# LLM_MODEL=gpt-4o-mini
